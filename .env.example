# =====================================================
# DIAN Tax Dashboard — variables de entorno
# Copia este archivo a `.env.local` y rellena los valores.
# =====================================================

# ---- Supabase (futuro — actualmente usa localStorage) ----
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ---- App config ----
# Nombre visible de la app
VITE_APP_NAME="DIAN Tax Dashboard"

# Modo demo: muestra banner amarillo y permite credenciales hardcoded
# Valores: "true" | "false"
VITE_DEMO_MODE=true

# Credenciales del usuario demo (solo si VITE_DEMO_MODE=true)
VITE_DEMO_EMAIL=demo@dian.co
VITE_DEMO_PASSWORD=demo1234

# ---- Tributario ----
# UVT (Unidad de Valor Tributario) vigente en COP — actualizar cada año fiscal
VITE_UVT_VALUE=49799
VITE_UVT_YEAR=2025

# ---- Telemetría (opcional) ----
# VITE_SENTRY_DSN=
# VITE_PLAUSIBLE_DOMAIN=
